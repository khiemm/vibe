FRED_API_KEY=
ALPHA_VANTAGE_API_KEY=
PRICES_API_LOGS=

# Cognito-backed auth settings for local and deployed environments.
AUTH_MODE=remote
APP_BASE_URL=http://localhost:3434
AUTH_COOKIE_NAME=vibe_session
AUTH_COOKIE_SECURE=false
AUTH_SESSION_SECRET=replace-with-a-32-character-or-longer-secret
AUTH_SESSION_REFRESH_WINDOW_SECONDS=120

AUTH_API_BASE_URL=https://example.execute-api.ap-southeast-1.amazonaws.com
AUTH_API_SERVICE_TOKEN=replace-with-the-secrets-manager-service-token
COGNITO_AWS_REGION=ap-southeast-1
COGNITO_USER_POOL_ID=ap-southeast-1_example
COGNITO_USER_POOL_CLIENT_ID=exampleclientid
COGNITO_ISSUER=https://cognito-idp.ap-southeast-1.amazonaws.com/ap-southeast-1_example
COGNITO_JWKS_URI=https://cognito-idp.ap-southeast-1.amazonaws.com/ap-southeast-1_example/.well-known/jwks.json
